# ══════════════════════════════════════════════════════════════
# NyayaSathi Backend - Environment Variables Template
# ══════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your actual values.
# NEVER commit your actual .env file to git.
# ══════════════════════════════════════════════════════════════

# ── Node environment ──────────────────────────────────────────
NODE_ENV=development          # "development" | "production"
PORT=5000

# ── MongoDB ───────────────────────────────────────────────────
# Local:   mongodb://localhost:27017/nyayasathi
MONGO_URI:   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/nyayasathi
# MONGO_URI=mongodb://localhost:27017/nyayasathi

# ── JWT ───────────────────────────────────────────────────────
# Use a long, random string (32+ chars) — do NOT reuse in prod
JWT_SECRET=change_me_to_a_secure_random_secret_32chars
JWT_REFRESH_SECRET=change_me_to_another_secure_random_secret
JWT_EXPIRE=7d

# ── Google Gemini AI ──────────────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_1=gemini-2.5-pro
GEMINI_FALLBACK_2=gemini-1.5-flash-latest
RAG_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=gemini-embedding-001
TOP_K=5
LLM_PROVIDER=google

# ── Pinecone (Vector DB) ──────────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENV=your_pinecone_environment
PINECONE_INDEX=nyayasathi-docs

# ── AWS S3 (Document Storage) ─────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
S3_BUCKET=nyayasathi
S3_REGION=ap-south-1

# ── Redis (Caching & Session Memory) ─────────────────────────
# Local:    redis://localhost:6379
# RedisLabs/Upstash: redis://default:<password>@<host>:<port>
REDIS_URL=redis://localhost:6379
REDIS_MEMORY_LIMIT=30

# ── SMTP / Email ──────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_SERVICE=gmail
SMTP_PORT=587
SMTP_MAIL=your_email@gmail.com
SMTP_PASSWORD=your_gmail_app_password   # Use App Password, not account password

# ── Contact form ──────────────────────────────────────────────
CONTACT_TO_EMAIL=your_team_email@gmail.com
CONTACT_FROM_NAME=NyayaSathi
CONTACT_FROM_EMAIL=noreply@yourdomain.com
CONTACT_RATE_LIMIT=5
CONTACT_AUTOREPLY=true

# ── CORS (comma-separated allowed frontend origins) ───────────
# Production: https://your-frontend.onrender.com,https://your-custom-domain.com
FRONTEND_URL=http://localhost:5173

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_MAX=100      # Max requests per IP per 15 minutes

# ── Cloudinary (optional: for avatar uploads) ─────────────────
CLOUDINARY_NAME=your_cloudinary_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
