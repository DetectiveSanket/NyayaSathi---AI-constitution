# ══════════════════════════════════════════════════════════════════════
# NyayaSathi Frontend — Environment Variables Template
# ══════════════════════════════════════════════════════════════════════
# 1. Copy this file to src/.env  (Vite reads from src/.env OR root .env)
# 2. Fill in your actual values.
# 3. Add ALL keys below to your Vercel dashboard → Project → Settings → Environment Variables.
# 4. NEVER commit the actual .env file (it is already in .gitignore).
#
# RULE: Every variable MUST start with VITE_
#       Access in code:  import.meta.env.VITE_SOMETHING
#       DO NOT use:      process.env.SOMETHING   ← breaks in Vite/browser
# ══════════════════════════════════════════════════════════════════════

# ── Backend API Base URL ───────────────────────────────────────────────
# Must end with a trailing slash.
# Local dev:
VITE_API_BASE_URL=http://localhost:5000/api/v1/
# Production (set this in Vercel dashboard):
# VITE_API_BASE_URL=https://nyayasathi-backend.onrender.com/api/v1/

# ── User / Auth Endpoints (relative paths appended to VITE_API_BASE_URL) ──
VITE_REGISTER_URL=user/register
VITE_LOGIN_URL=user/login
VITE_LOGOUT_URL=user/logout
VITE_REFRESH_TOKEN_URL=user/refresh-token
VITE_FORGOT_PASSWORD_URL=user/forgot-password
VITE_RESET_PASSWORD_URL=user/reset-password
VITE_VERIFY_EMAIL_URL=user/verify-email
VITE_RESEND_OTP_URL=user/resend-otp
VITE_GET_USER_PROFILE_URL=user/me
VITE_UPDATE_USER_PROFILE_URL=user/me